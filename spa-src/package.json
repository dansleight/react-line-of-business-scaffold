{
  "name": "line-of-business",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "webapibuild": "tsc -b && vite build --emptyOutDir --outDir ../src/Scaffold/ClientApp/dist",
    "fastapibuild": "tsc -b && vite build --emptyOutDir --outDir=../python-src/client_app --base=/static/",
    "testbuild": "tsc -b && vite build && rimraf --glob ./*.tsbuildinfo && rimraf --glob ./dist",
    "lint": "eslint .",
    "preview": "vite preview",
    "update-npm": "npm cache verify && npx --yes npm-check-updates --target minor -u && npm update",
    "update-api": "node generate-api.js"
  },
  "dependencies": {
    "@azure/msal-browser": "^4.26.2",
    "@azure/msal-react": "^3.0.22",
    "@fortawesome/fontawesome-common-types": "^6.7.2",
    "@fortawesome/free-regular-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.6",
    "@hookform/resolvers": "^5.2.2",
    "@metismenu/react": "^0.0.3",
    "bootstrap": "^5.3.8",
    "bootswatch": "^5.3.8",
    "classnames": "^2.5.1",
    "crypto-js": "^4.2.0",
    "easymde": "^2.20.0",
    "lodash": "^4.17.21",
    "metismenujs": "^1.4.0",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.67.0",
    "react-router-dom": "^7.9.6",
    "react-use-cookie": "^1.6.1",
    "simplebar-react": "^3.3.2",
    "ts-morph": "^26.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bootstrap": "^5.2.10",
    "@types/crypto-js": "^4.2.2",
    "@types/lodash": "^4.17.21",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "axios": "^1.13.2",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fs": "^0.0.2",
    "globals": "^15.15.0",
    "openapi-types": "^12.1.3",
    "rimraf": "^6.1.2",
    "sass-embedded": "^1.93.3",
    "swagger-typescript-api": "13.2.16",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^6.4.1"
  },
  "prettier": {
    "overrides": [
      {
        "files": "routes.tsx",
        "options": {
          "printWidth": 200,
          "arrowParens": "avoid"
        }
      }
    ]
  }
}
