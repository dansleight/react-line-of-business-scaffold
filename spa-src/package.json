{
  "name": "line-of-business",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build --emptyOutDir --outDir ../src/AiProto/ClientApp/dist",
    "pythonbuild": "tsc -b && vite build --emptyOutDir --outDir=../python-src/client_app --base=/static/",
    "testbuild": "tsc -b && vite build && rm *.tsbuildinfo && rm -rf dist",
    "lint": "eslint .",
    "preview": "vite preview",
    "update-npm": "npm cache verify && npx --yes npm-check-updates --target minor -u && npm update",
    "update-api": "rm -f src/apiClient/*.ts && node generate-api.js",
    "update-python-api": "rm -f src/apiClient/*.ts && node generate-python-api.js",
    "generate-zod-schema": "ts-node generateZodSchema.ts"
  },
  "dependencies": {
    "@azure/msal-browser": "^4.20.0",
    "@azure/msal-react": "^3.0.18",
    "@fortawesome/fontawesome-common-types": "^6.7.2",
    "@fortawesome/free-regular-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.3",
    "@hookform/resolvers": "^5.2.1",
    "@metismenu/react": "^0.0.3",
    "bootstrap": "^5.3.7",
    "bootswatch": "^5.3.7",
    "classnames": "^2.5.1",
    "crypto-js": "^4.2.0",
    "easymde": "^2.20.0",
    "lodash": "^4.17.21",
    "metismenujs": "^1.4.0",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.62.0",
    "react-router-dom": "^7.8.1",
    "react-use-cookie": "^1.6.1",
    "simplebar-react": "^3.3.2",
    "ts-morph": "^26.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/bootstrap": "^5.2.10",
    "@types/crypto-js": "^4.2.2",
    "@types/lodash": "^4.17.20",
    "@types/node": "^24.3.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "axios": "^1.11.0",
    "dotenv": "^16.6.1",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "fs": "^0.0.1-security",
    "globals": "^15.15.0",
    "openapi-types": "^12.1.3",
    "sass-embedded": "^1.90.0",
    "swagger-typescript-api": "13.1.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.39.1",
    "vite": "^6.3.5"
  },
  "prettier": {
    "overrides": [
      {
        "files": "routes.tsx",
        "options": {
          "printWidth": 200,
          "arrowParens": "avoid"
        }
      }
    ]
  }
}
